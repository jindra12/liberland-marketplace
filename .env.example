# Database connection string
DATABASE_URL=mongodb://127.0.0.1/your-database-name

# Or use a PG connection string
#DATABASE_URL=postgresql://127.0.0.1:5432/your-database-name

# Used to encrypt JWT tokens
PAYLOAD_SECRET=YOUR_SECRET_HERE

# Optional salt for comment author hashes (falls back to PAYLOAD_SECRET if unset)
COMMENTS_HASH_SALT=YOUR_OPTIONAL_HASH_SALT

# Enable verbose Payload error responses and stack traces (non-public envs only)
PAYLOAD_DEBUG=false

# Payload logger level: trace, debug, info, warn, error, fatal
PAYLOAD_LOG_LEVEL=info

# Used to configure CORS, format links and more. No trailing slash
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Secret used to authenticate cron jobs
CRON_SECRET=YOUR_CRON_SECRET_HERE

# Used to validate preview requests
PREVIEW_SECRET=YOUR_SECRET_HERE

# Better Auth — used for session encryption
BETTER_AUTH_SECRET=YOUR_BETTER_AUTH_SECRET_HERE

# Vercel Blob read/write token (required for media storage plugin)
BLOB_READ_WRITE_TOKEN=YOUR_BLOB_RW_TOKEN

# Google OAuth credentials (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=googleclientid
GOOGLE_CLIENT_SECRET=googleclientsecret

# Frontend marketplace URL (where users are redirected after actions like email verification)
NEXT_PUBLIC_FRONTEND_URL=http://localhost:3001

# OIDC Provider — credentials for frontend app acting as OIDC client
OIDC_CLIENT_ID=frontend-app
OIDC_CLIENT_SECRET=your-oidc-client-secret
OIDC_REDIRECT_URLS=http://localhost:3001/auth/callback

# SMTP — email transport for verification emails (use Mailtrap/Ethereal for dev)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_FROM_ADDRESS=noreply@liberland.org
SMTP_FROM_NAME=Liberland Marketplace

# Crypto pricing + payment verification
# Thirdweb (optional, recommended for resilient Ethereum RPC)
# Server-side usage prefers secret key; client ID is fallback.
THIRDWEB_SECRET_KEY=your-thirdweb-secret-key
THIRDWEB_CLIENT_ID=your-thirdweb-client-id
# Optional per-chain rate fetch timeout (ms) to prevent slow order creation.
CRYPTO_RATE_FETCH_TIMEOUT_MS=8000

# Ethereum (Uniswap V2 WETH/USDC pool)
CRYPTO_ETH_RPC_URL=https://ethereum-rpc.publicnode.com
CRYPTO_ETH_POOL_ADDRESS=0xB4e16d0168e52d35CaCD2c6185b44281Ec28C9Dc
CRYPTO_ETH_NATIVE_TOKEN_ADDRESS=0xC02aaA39b223FE8D0A0E5C4F27eAD9083C756Cc2
CRYPTO_ETH_STABLE_TOKEN_ADDRESS=0xA0b86991c6218b36c1d19d4a2e9eb0ce3606eb48
CRYPTO_ETH_NATIVE_TOKEN_SYMBOL=ETH
CRYPTO_ETH_STABLE_TOKEN_SYMBOL=USDC
CRYPTO_ETH_NATIVE_TOKEN_DECIMALS=18
CRYPTO_ETH_STABLE_TOKEN_DECIMALS=6

# Solana (Raydium SOL/USDC pool vault token accounts)
CRYPTO_SOL_RPC_URL=https://api.mainnet-beta.solana.com
CRYPTO_SOL_POOL_ADDRESS=58oQChx4yWmvKdwLLZzBi4ChoCc2fqCUWBkwMihLYQo2
CRYPTO_SOL_POOL_NATIVE_VAULT_ADDRESS=DQyrAcCrDXQ7NeoqGgDCZwBvWDcYmFCjSb9JtteuvPpz
CRYPTO_SOL_POOL_STABLE_VAULT_ADDRESS=HLmqeL62xR1QoZ1HKKbXRrdN1p3phKpxRMb2VVopvBBz
CRYPTO_SOL_NATIVE_TOKEN_SYMBOL=SOL
CRYPTO_SOL_STABLE_TOKEN_SYMBOL=USDC
CRYPTO_SOL_SPL_TOKEN_MINT_ADDRESS=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v

# TRON (SunSwap V2 WTRX/USDT pair + TronGrid connection)
TRONWEB_FULLNODE=https://api.trongrid.io
TRONWEB_API=https://api.trongrid.io
TRONWEB_SECRET=your-trongrid-api-key
CRYPTO_TRON_POOL_ADDRESS=TFGDbUyP8xez44C76fin3bn3Ss6jugoUwJ
CRYPTO_TRON_NATIVE_TOKEN_ADDRESS=TNUC9Qb1rRpS5CbWLmNMxXBjyFoydXjWFR
CRYPTO_TRON_STABLE_TOKEN_ADDRESS=TR7NHqjeKQxGTCi8q8ZY4pL8otSzgjLj6t
